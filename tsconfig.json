{
	"compilerOptions": {
        "importHelpers": true,
		"module": "es6",
		"esModuleInterop": true,
		"target": "es6",
        "moduleResolution": "node",
        "downlevelIteration": true,
        "allowSyntheticDefaultImports": true,
        "outDir": "lib",
        "declaration": true
	},
	"include": ["src/", "tests/"],
	"exclude": ["node_modules"],
	"lib": ["es2015", "es2016", "es2017", "es2018", "es2019", "es2020"]
}
 